{
  "build": {
    "content": [
      {
        "files": [ "index.md", "toc.yml" ]
      },
      {
        "files": [ "modules/**.md", "modules/**/toc.yml" ],
        "src": "."
      },
      {
        "files": [ "dnnrocket/**.md", "dnnrocket/**/toc.yml" ],
        "src": "."
      },
      {
        "files": [ "appthemes/**.md", "appthemes/**/toc.yml" ],
        "src": "."
      },
      {
        "files": [ "razortokens/**.md", "razortokens/**/toc.yml" ],
        "src": "."
      },
      {
        "files": [ "snippets/**.md", "snippets/**/toc.yml" ],
        "src": "."
      },
      {
        "files": [ "tutorial/**.md", "tutorial/**/toc.yml" ],
        "src": "."
      }
    ],
    "resource": [
      {
        "files": [
          "logo/**",
          "imgs/**"
        ]
      }
    ],
    "template": [
      "default",
      "modern",
      "templates/material/material"
    ],
    "globalMetadata": {
      "_appTitle": "DNNrocket Documentation",
      "_appFooter": "DNNrocket Project",
      "_enableSearch": true,
      "_appLogoPath": "logo/icon-32.png",
      "_appFaviconPath": "logo/facicon.ico",
      "_language": "en"
    },
    "dest": "_site",
    "cleanupOutputFolder": true,
    "disableGitFeatures": false
  }
}
