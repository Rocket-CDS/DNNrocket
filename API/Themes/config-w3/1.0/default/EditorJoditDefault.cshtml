@inherits DNNrocketAPI.render.DNNrocketTokens<Simplisity.SimplisityRazor>
@using DNNrocketAPI.Components;
@using Simplisity;

@AddProcessData("resourcepath", "/DesktopModules/DNNrocket/API/App_LocalResources/")

<link rel="stylesheet" href="/DesktopModules/DNNrocket/API/Editor/Jodit/jodit.min.css" />

<style>
    /* Source mode: white background */
    .jodit-source__mirror {
        background-color: #ffffff !important;
        color: #000000 !important;
    }

    /* Remove italic preview in toolbar button only */
    .jodit-toolbar-button[aria-label*="Italic"] {
        font-style: normal !important;
    }

    /* Remove blockquote preview in toolbar button only */
    .jodit-toolbar-button[aria-label*="quote"] {
        font-style: normal !important;
    }
</style>

<div class="container">
    <div class="control-group">
        <div id="jodit-editor-@Model.GetSetting("editor_id")"></div>
    </div>
    @HiddenField(new SimplisityInfo(), Model.GetSetting("editor_xpath"), "", Model.GetSetting("editor_richtext"))
</div>

<script>
(function() {
    // Load Jodit script dynamically and wait for it to load
    function loadJoditScript(callback) {
        if (typeof Jodit !== 'undefined') {
            callback();
            return;
        }

        const script = document.createElement('script');
        script.src = '/DesktopModules/DNNrocket/API/Editor/Jodit/jodit.min.js';
        script.onload = function() {
            console.log('Jodit script loaded');
            callback();
        };
        script.onerror = function() {
            console.error('Failed to load Jodit script');
        };
        document.head.appendChild(script);
    }

    // Initialize Jodit editor after script loads
    loadJoditScript(function() {
        const editorId = '@Model.GetSetting("editor_id")';
        const hiddenField = document.getElementById(editorId);
        const editorContainer = '#jodit-editor-' + editorId;
        const initialContent = `@HtmlOf(Model.GetSetting("editor_richtext"))`;

        function normalizeSemanticHtml(html) {
            if (!html) {
                return html;
            }

            return html
                .replace(/<o:p[^>]*>(?:\s|&nbsp;)*<\/o:p>/gi, '')
                .replace(/<\/?o:p[^>]*>/gi, '')
                .replace(/<\s*b(\s|>)/gi, '<strong$1')
                .replace(/<\s*\/\s*b\s*>/gi, '</strong>')
                .replace(/<\s*i(\s|>)/gi, '<em$1')
                .replace(/<\s*\/\s*i\s*>/gi, '</em>');
        }

        function unwrapHeadingInlineWrappers(html) {
            if (!html) {
                return html;
            }

            try {
                const parser = new DOMParser();
                const doc = parser.parseFromString('<div id="jodit-normalize-root">' + html + '</div>', 'text/html');
                const root = doc.getElementById('jodit-normalize-root');

                if (!root) {
                    return html;
                }

                root.querySelectorAll('h1,h2,h3,h4,h5,h6').forEach(function (heading) {
                    heading.querySelectorAll('span,font').forEach(function (node) {
                        const parent = node.parentNode;

                        if (!parent) {
                            return;
                        }

                        while (node.firstChild) {
                            parent.insertBefore(node.firstChild, node);
                        }

                        parent.removeChild(node);
                    });
                });

                root.querySelectorAll('*').forEach(function (node) {
                    const tagName = node.tagName ? node.tagName.toLowerCase() : '';

                    if (tagName === 'span' || tagName === 'font') {
                        const parent = node.parentNode;

                        if (!parent) {
                            return;
                        }

                        while (node.firstChild) {
                            parent.insertBefore(node.firstChild, node);
                        }

                        parent.removeChild(node);
                        return;
                    }

                    node.removeAttribute('style');
                    node.removeAttribute('class');
                    node.removeAttribute('lang');
                    node.removeAttribute('align');
                    node.removeAttribute('face');
                    node.removeAttribute('size');
                    node.removeAttribute('color');
                });

                return root.innerHTML;
            } catch (e) {
                return html;
            }
        }

        function normalizeEditorHtml(html) {
            const semanticHtml = normalizeSemanticHtml(html);
            return unwrapHeadingInlineWrappers(semanticHtml);
        }

        // Check if editor already exists for this ID
        if (hiddenField && hiddenField.joditInstance) {
            console.log('Jodit editor already initialized for:', editorId);
            return;
        }

        // Configure Jodit editor to match https://xdsoft.net/jodit/play.html demo
        const config = {
            language: '@DNNrocketUtils.GetLanguageCode(DNNrocketUtils.GetCurrentCulture())',
            toolbar: true,
            textIcons: function (key) {
                return key === 'paragraph';
            },
            toolbarButtonSize: 'middle',
            toolbarAdaptive: false,
            toolbarSticky: false,
            showCharsCounter: true,
            showWordsCounter: true,
            showXPathInStatusbar: false,
            uploader: false,
            filebrowser: false,
            buttons: [
                'source', '|',
                'undo', 'redo', '|',
                'bold', 'italic', 'underline', 'strikethrough', '|',
                'ul', 'ol', '|',
                'hr', '|',
                'align', '|',
                'link', '|',
                'paragraph'
            ],
            popup: {
                a: Jodit.atom([
                    {
                        name: 'open_link',
                        icon: 'eye',
                        exec: function (editor, current, close) {
                            const href = current.getAttribute('href');
                            if (href) { window.open(href, '_blank'); }
                            close();
                        }
                    },
                    '|',
                    {
                        name: 'link',
                        icon: 'pencil',
                        exec: function (editor, current, close) {
                            editor.selection.select(current);
                            editor.execCommand('link');
                            close();
                        }
                    },
                    '|',
                    'unlink'
                ])
            },
            controls: {
                paragraph: {
                    list: Jodit.atom({
                        p: 'Normal',
                        h1: 'Heading 1',
                        h2: 'Heading 2',
                        h3: 'Heading 3',
                        h4: 'Heading 4',
                        blockquote: 'Quote'
                    })
                },
                ul: {
                    list: Jodit.atom({
                        default: 'Default',
                        disc: 'Dot'
                    })
                },
                ol: {
                    list: Jodit.atom({
                        default: 'Default',
                        'lower-alpha': 'a, b, c'
                    })
                }
            },
            enter: 'P',
            defaultMode: Jodit.MODE_WYSIWYG,
            useSplitMode: false,
            minHeight: 300,
            height: 500,
            pasteHTMLActionList: [
                { value: Jodit.constants.INSERT_CLEAR_HTML, text: '@ResourceKey("DNNrocket.jodittidy")' },
                { value: Jodit.constants.INSERT_ONLY_TEXT, text: '@ResourceKey("DNNrocket.jodittextonly")' }
            ],
            askBeforePasteHTML: false,
            askBeforePasteFromWord: false,
            defaultActionOnPaste: Jodit.constants.INSERT_CLEAR_HTML,
            processPasteHTML: true,
            cleanHTML: {
                fillEmptyParagraph: false,
                removeEmptyElements: false,
                replaceNBSP: false,
                replaceOldTags: true
            },
            beautifyHTML: true,
            pasteFromWordActionList: [
                { value: Jodit.constants.INSERT_AS_TEXT, text: '@ResourceKey("DNNrocket.jodittidy")' },
                { value: Jodit.constants.INSERT_ONLY_TEXT, text: '@ResourceKey("DNNrocket.jodittextonly")' }
            ],
            useSearch: true,
            enableDragAndDropFileToEditor: false,
            uploader: {
                insertImageAsBase64URI: true,
                imagesExtensions: ['jpg', 'png', 'jpeg', 'gif', 'svg', 'webp']
            },
            filebrowser: {
                ajax: {
                    url: ''
                }
            },
            events: {
                beforePaste: function (html) {
                    return normalizeEditorHtml(html);
                },
                change: function(value) {
                    if (hiddenField) {
                        const normalizedValue = normalizeEditorHtml(value);
                        hiddenField.value = normalizedValue;
                        // Trigger change event for form dirty tracking
                        const isDirtyField = document.getElementById('isdirty');
                        if (isDirtyField) {
                            isDirtyField.value = 'true';
                        }
                    }
                },
                afterInit: function(instance) {
                    console.log('Jodit editor initialized for:', editorId);
                }
            },
            iframe: true,
            iframeDefaultSrc: 'about:blank',
            iframeCSSLinks: ['@PortalUtils.GetCurrentPortalCssPath()','@PortalUtils.GetCurrentPageSkinCssPath()'],
            iframeStyle: 'html,body{margin:0;padding:20px;background:#fff;color:#000;} em,i{font-style:italic;} strong,b{font-weight:bold;}'
        };

        // Initialize Jodit editor with unique container
        const editor = Jodit.make(editorContainer, config);

        // Store editor instance reference on hidden field to prevent duplicate initialization
        if (hiddenField) {
            hiddenField.joditInstance = editor;
        }

        // Set initial content
        if (initialContent) {
            editor.value = normalizeEditorHtml(initialContent);
        }

        // Watch for changes in the hidden field and update editor
        if (hiddenField) {
            // Use MutationObserver to watch for value changes
            const observer = new MutationObserver(() => {
                const newContent = hiddenField.value;
                const normalizedContent = normalizeEditorHtml(newContent);
                if (normalizedContent !== editor.value) {
                    editor.value = normalizedContent;
                    console.log('Jodit editor updated from hidden field:', normalizedContent);
                }
            });

            // Observe attribute changes on the hidden field
            observer.observe(hiddenField, { attributes: true, attributeFilter: ['value'] });

            // Also listen for input/change events
            hiddenField.addEventListener('input', (e) => {
                const newContent = e.target.value;
                const normalizedContent = normalizeEditorHtml(newContent);
                if (normalizedContent !== editor.value) {
                    editor.value = normalizedContent;
                    console.log('Jodit editor updated from hidden field:', normalizedContent);
                }
            });

            hiddenField.addEventListener('change', (e) => {
                const newContent = e.target.value;
                const normalizedContent = normalizeEditorHtml(newContent);
                if (normalizedContent !== editor.value) {
                    editor.value = normalizedContent;
                    console.log('Jodit editor updated from hidden field:', normalizedContent);
                }
            });
        }
    });
})();
</script>
